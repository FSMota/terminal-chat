{
  "compilerOptions": {
    /* Módulos e Versão do JS */
    "target": "es2024",                                  
    "module": "commonjs",                                
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    
    /* Diretórios */
    "rootDir": "./api",        /* Onde ficam seus arquivos .ts */
    "outDir": "./dist",        /* Onde o código compilado (.js) vai parar */
    
    /* Interoperabilidade */
    "esModuleInterop": true,   /* Facilita importar pacotes que não usam "export default" */
    "forceConsistentCasingInFileNames": true,
    
    /* Verificação de Tipos (Strict Mode) */
    "strict": true,            /* Ativa todas as verificações rigorosas do TS */
    "skipLibCheck": true       /* Ignora erros de tipagem dentro da pasta node_modules (acelera a compilação) */
  },
  "include": ["api/**/*"],     /* Diz ao TS para compilar tudo que está na pasta api */
  "exclude": ["node_modules", "dist", "**/*.spec.ts"]
}